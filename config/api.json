{
  "sites": [
    {
      "name": "Hacker News",
      "org_key": "hackernews",
      "base_url": "https://hacker-news.firebaseio.com/v0",
      "favicon": "https://news.ycombinator.com/favicon.ico",
      "pages": [
        {
          "key": "best",
          "endpoint": "/beststories.json",
          "method": "GET",
          "output_file": "hackernews_best.xml",
          "params": {},
          "limit": 50
        }
      ]
    },
    {
      "name": "Hugging Face",
      "org_key": "huggingface",
      "base_url": "https://huggingface.co/api",
      "favicon": "https://huggingface.co/favicon.ico",
      "pages": [
        {
          "key": "trending_models",
          "endpoint": "/trending",
          "method": "GET",
          "params": { "type": "model", "limit": 20 },
          "output_file": "huggingface_trending_models.xml"
        },
        {
          "key": "trending_datasets",
          "endpoint": "/trending",
          "method": "GET",
          "params": { "type": "dataset", "limit": 20 },
          "output_file": "huggingface_trending_datasets.xml"
        },
        {
          "key": "daily_papers",
          "endpoint": "/daily_papers",
          "method": "GET",
          "params": {},
          "output_file": "huggingface_daily_papers.xml"
        }
      ]
    }
  ]
}
