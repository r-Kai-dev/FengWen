{
  "sites": [
    {
      "name": "Hacker News",
      "org_key": "hackernews",
      "base_url": "https://hacker-news.firebaseio.com/v0",
      "favicon": "https://news.ycombinator.com/favicon.ico",
      "pages": [
        {
          "key": "best",
          "endpoint": "/beststories.json",
          "method": "GET",
          "output_file": "hackernews_best.xml",
          "params": {},
          "limit": 50
        }
      ]
    },
    {
      "name": "Hugging Face",
